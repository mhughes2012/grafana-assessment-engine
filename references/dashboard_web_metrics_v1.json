{
  "dashboard": {
    "id": null,
    "uid": "prod-web-metrics-001",
    "title": "Production Web Services",
    "tags": ["templated", "assessment"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "panels": [
      {
        "title": "HTTP 5xx Error Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "datasource": {
          "type": "prometheus",
          "uid": "prom-ds-01"
        },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m]))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "red", "value": 10 }
              ]
            }
          }
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "interval",
          "type": "interval",
          "query": "1m,5m,15m,1h"
        }
      ]
    }
  }
}